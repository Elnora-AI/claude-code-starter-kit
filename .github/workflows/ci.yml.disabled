# Minimal CI template — runs on push and pull requests
# Docs: https://docs.github.com/actions
#
# To enable: rename this file to `ci.yml`
# Update the build/test steps to match your project's stack.

name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
