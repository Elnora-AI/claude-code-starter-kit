# ============================================================
# Environment & Secrets — NEVER commit these
# ============================================================
.env
.env.*
!.env.template
!.env.example
*.env

# Credential and secret files (any name/path)
**/credentials*.json
**/secrets*.json
**/auth*.json
**/*token*.json
**/*secret*.json
**/api-key*
**/apikey*

# Private keys and certificates
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
*.crt
*.cer
id_rsa*
id_ed25519*
id_ecdsa*

# SSH
.ssh/

# Cloud provider credentials
.aws/
aws-credentials*
gcp-*.json
*-keyfile.json
service-account*.json
.azure/
azure-*.json

# Elnora CLI — defensive: the CLI normally writes to ~/.elnora/ (outside
# any repo), but if a future version ever drops a project-local config it
# would carry an elnora_live_* API key, which must never be committed.
.elnora/
.elnora-config*

# Terraform state (may contain secrets)
*.tfstate
*.tfstate.*
.terraform/

# ============================================================
# Claude Code — local settings are per-user
# ============================================================
.claude/settings.local.json
.claude/knowledge-base.local.md
# Ephemeral lock files written by the harness (e.g. scheduled_tasks.lock)
.claude/*.lock

# Setup-time integrity marker. install.sh / install.ps1 write this on
# fresh extract; setup-mac.sh / setup-windows.ps1 verify the SHA against
# INSTALL_FOR_AGENTS.md before handing off to claude. It's scaffolding,
# not user content — keep it out of customers' initial commit.
.elnora-starter-kit-marker

# Runtime scratch folder — regenerable state, logs, downloaded artifacts
# Keep the folder (README + .gitkeep) but ignore everything else inside
cache/*
!cache/README.md
!cache/.gitkeep

# ============================================================
# OS files
# ============================================================
.DS_Store
Thumbs.db
Desktop.ini
._*

# ============================================================
# Editor / IDE files
# ============================================================
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~

# ============================================================
# Node.js
# ============================================================
node_modules/
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.Python
*.egg-info/
dist/
build/

# ============================================================
# .NET / C#
# ============================================================
bin/
obj/
*.user
*.suo

# ============================================================
# Build outputs & logs
# ============================================================
*.log
logs/
tmp/
temp/
test-logs/
