# ============================================================
# Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.template .env
#
# IMPORTANT: Never commit .env to Git — it's in .gitignore
# ============================================================

# Claude Code Authentication
# --------------------------
# If you're on a Claude Teams plan, you don't need an API key —
# Claude Code authenticates through your browser when you first run it.
# Only uncomment this if you're using API key authentication:
# ANTHROPIC_API_KEY=sk-ant-...

# GitHub
# ------
# Usually auto-managed by Claude's /install-github-app command.
# Only set manually if you need a specific token:
# GITHUB_TOKEN=ghp_...

# Elnora AI
# ---------
# The easy path: run `elnora auth login` after setup — browser OAuth, no manual
# key handling. The pre-wired MCP server at https://mcp.elnora.ai/mcp also opens
# a browser on first use.
# Manual path: get a key at https://platform.elnora.ai/settings/api-keys and
# uncomment below (used as a fallback when OAuth isn't available):
# ELNORA_API_KEY=

# Optional: MCP Server Keys
# -------------------------
# Add API keys here as you connect more tools.
# Examples (uncomment and fill in as needed):
# LINEAR_API_KEY=lin_api_...
# SLACK_BOT_TOKEN=xoxb-...
# NOTION_API_KEY=ntn_...
