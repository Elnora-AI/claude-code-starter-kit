# ============================================================
# Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.template .env
#
# IMPORTANT: Never commit .env to Git — it's in .gitignore
# ============================================================

# Claude Code Authentication
# --------------------------
# If you're on a Claude Teams plan, you don't need an API key —
# Claude Code authenticates through your browser when you first run it.
# Only uncomment this if you're using API key authentication:
# ANTHROPIC_API_KEY=sk-ant-...

# GitHub
# ------
# Usually auto-managed by Claude's /install-github-app command.
# Only set manually if you need a specific token:
# GITHUB_TOKEN=ghp_...

# Optional: MCP Server Keys
# -------------------------
# Add API keys here as you connect more tools.
# Examples (uncomment and fill in as needed):
# LINEAR_API_KEY=lin_api_...
# SLACK_BOT_TOKEN=xoxb-...
# NOTION_API_KEY=ntn_...
