# ============================================================
# Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.template .env
#
# IMPORTANT: Never commit .env to Git — it's in .gitignore.
# Claude Code itself authenticates through your Pro/Max
# subscription (browser login on first run); no API key needed
# for normal use.
# ============================================================

# Your Elnora API key.
# Get one at: https://platform.elnora.ai/settings → API Keys tab → Create key.
# The key starts with elnora_live_.
ELNORA_API_KEY=

# ------------------------------------------------------------
# Handoff end-to-end test only — leave blank for normal use
# ------------------------------------------------------------
# Used by tests/handoff/ + the handoff-e2e GitHub workflow to run
# Claude in headless mode (`claude -p`) so we can verify what Claude
# actually does after Phase 1 hands off. Normal Claude Code use does
# NOT need this — Pro/Max OAuth handles auth interactively.
#
# Get one at: https://console.anthropic.com/settings/keys
# Set a low monthly budget cap on the key so a runaway test can't
# spike the bill.
ANTHROPIC_API_KEY=
